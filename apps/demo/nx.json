{
  "$schema": "../../node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*"],
    "production": ["default"]
  },
  "targetDefaults": {
    "build": {
      "cache": false
    },
    "typecheck": {
      "cache": false,
      "inputs": [
        "{projectRoot}/**/*",
        "{projectRoot}/tsconfig.json",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "lint": {
      "cache": false
    },
    "format": {
      "cache": false
    },
    "test": {
      "cache": false
    }
  },
  "plugins": [
    {
      "plugin": "../../packages/typescript-preset/src/plugin.ts",
      "options": { "tsgo": false }
    },
    "../../packages/tsdown/src/index.ts",
    "../../packages/oxlint/src/plugin.ts",
    "../../packages/biome/src/plugin.ts"
  ]
}
