{
  "name": "nx-devkit-plugins",
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "packageManager": "bun@1.3.14",
  "version": 2,
  "plugins": [
    { "plugin": "@nx-devkit/tsdown" },
    { "plugin": "@nx-devkit/oxlint" },
    { "plugin": "@nx-devkit/biome" },
    { "plugin": "@nx-devkit/typescript", "options": { "tsgo": false } }
  ],
  "namedInputs": {
    "sharedGlobals": [
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/biome.json",
      "{workspaceRoot}/.oxlintrc.json"
    ]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "cache": true
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true
    }
  }
}
