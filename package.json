{
  "name": "nx-devkit-plugins",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zero-config Nx plugin inference for tsdown, oxlint, biome, typescript/vitest",
  "workspaces": [
    "packages/*",
    "apps/*",
    "skills/*"
  ],
  "scripts": {
    "build": "bun run --filter='./packages/*' build",
    "test": "bun run --filter='./packages/*' test",
    "lint": "biome lint . && oxlint .",
    "lint:oxlint": "oxlint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "spec:check": "bun run scripts/spec-check.ts",
    "check:spec": "bun run scripts/spec-check.ts",
    "spec:validate": "openspec validate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@fission-ai/openspec": "^1.4.1",
    "@nx/devkit": "22.7.1",
    "@types/node": "^20.19.0",
    "husky": "^9.1.7",
    "nx": "22.7.1",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.3",
    "@typescript/native-preview": "^7.0.0-dev.20260622.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.18.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
