{
  "name": "nx-devkit-plugins",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Zero-config Nx plugin inference for tsdown, oxlint, biome, typescript/vitest",
  "workspaces": [
    "packages/*",
    "apps/*",
    "skills/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "lint": "nx run-many -t lint",
    "format": "nx run-many -t format",
    "test": "nx run-many -t test",
    "typecheck": "nx run-many -t typecheck",
    "ci": "nx run-many -t build lint test typecheck",
    "spec:check": "bun run scripts/spec-check.ts",
    "spec:validate": "openspec validate",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@fission-ai/openspec": "^1.4.1",
    "@nx/devkit": "22.7.1",
    "@types/node": "^26.0.0",
    "husky": "^9.1.7",
    "nx": "22.7.1",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=20.19.0",
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.14"
}
