{
  "name": "@nx-devkit/typescript",
  "version": "0.0.0",
  "license": "MIT",
  "private": false,
  "type": "module",
  "description": "Preset Nx plugin that infers typecheck and vitest test targets from tsconfig.json and vitest.config.* without any project.json.",
  "main": "./src/plugin.ts",
  "module": "./src/plugin.ts",
  "types": "./src/plugin.ts",
  "exports": {
    ".": {
      "types": "./src/plugin.ts",
      "default": "./src/plugin.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@nx/devkit": "^22.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.22.3",
    "vitest": "^4.1.9"
  }
}
